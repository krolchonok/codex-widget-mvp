<?xml version="1.0" encoding="utf-8"?>
<resources>
  <style name="Theme.CodexWidgetMvp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
    <item name="colorPrimary">@color/card_primary</item>
    <item name="colorPrimaryVariant">@color/card_primary</item>
    <item name="colorSecondary">@color/chip_bg</item>
    <item name="android:statusBarColor">@color/screen_bg</item>
    <item name="colorSurface">@color/card_surface</item>
  </style>

  <style name="WidgetActionButton" parent="Widget.MaterialComponents.Button">
    <item name="android:textAllCaps">false</item>
    <item name="android:textSize">16sp</item>
    <item name="android:minHeight">56dp</item>
    <item name="cornerRadius">18dp</item>
    <item name="backgroundTint">@color/button_secondary_bg</item>
    <item name="android:textColor">@color/button_secondary_text</item>
    <item name="rippleColor">@color/chip_bg</item>
    <item name="android:gravity">center</item>
    <item name="android:insetTop">0dp</item>
    <item name="android:insetBottom">0dp</item>
  </style>

  <style name="WidgetPrimaryButton" parent="Widget.MaterialComponents.Button">
    <item name="android:textAllCaps">false</item>
    <item name="android:textSize">16sp</item>
    <item name="android:minHeight">56dp</item>
    <item name="cornerRadius">20dp</item>
    <item name="backgroundTint">@color/button_primary_bg</item>
    <item name="android:textColor">@color/button_primary_text</item>
    <item name="rippleColor">@color/chip_bg</item>
    <item name="android:gravity">center</item>
    <item name="android:insetTop">0dp</item>
    <item name="android:insetBottom">0dp</item>
  </style>
</resources>
