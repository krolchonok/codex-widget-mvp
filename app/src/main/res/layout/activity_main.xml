<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/screen_bg"
  android:fitsSystemWindows="true">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:cardBackgroundColor="@color/card_primary"
      app:cardCornerRadius="28dp"
      app:strokeColor="@color/card_primary_stroke"
      app:strokeWidth="1dp">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/title_main"
          android:textAppearance="?attr/textAppearanceHeadlineMedium"
          android:textColor="@color/hero_text"
          android:textSize="32sp"
          android:textStyle="bold" />

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="8dp"
          android:text="@string/subtitle_main"
          android:textAppearance="?attr/textAppearanceBodyMedium"
          android:textColor="@color/hero_subtext"
          android:textSize="16sp"
          android:lineSpacingExtra="2dp" />

        <TextView
          android:id="@+id/summaryText"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="16dp"
          android:background="@drawable/summary_chip_bg"
          android:paddingLeft="12dp"
          android:paddingTop="8dp"
          android:paddingRight="12dp"
          android:paddingBottom="8dp"
          android:textColor="@color/chip_text"
          android:textSize="15sp"
          android:textStyle="bold" />
      </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      app:cardBackgroundColor="@color/card_surface"
      app:cardCornerRadius="24dp"
      app:strokeColor="@color/card_stroke"
      app:strokeWidth="1dp">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/section_auth"
          android:textAppearance="?attr/textAppearanceTitleMedium"
          android:textColor="@color/text_primary"
          android:textSize="22sp"
          android:textStyle="bold" />

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="6dp"
          android:text="@string/section_auth_subtitle"
          android:textAppearance="?attr/textAppearanceBodySmall"
          android:textColor="@color/text_muted"
          android:textSize="14sp"
          android:lineSpacingExtra="2dp" />

        <EditText
          android:id="@+id/authJsonInput"
          android:layout_width="match_parent"
          android:layout_height="240dp"
          android:layout_marginTop="14dp"
          android:background="@drawable/input_bg"
          android:gravity="top|start"
          android:hint="@string/hint_auth_json"
          android:inputType="textMultiLine|textNoSuggestions"
          android:overScrollMode="ifContentScrolls"
          android:padding="14dp"
          android:textColor="@color/text_primary"
          android:textColorHint="@color/text_muted"
          android:textSize="15sp" />
      </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      app:cardBackgroundColor="@color/card_surface"
      app:cardCornerRadius="24dp"
      app:strokeColor="@color/card_stroke"
      app:strokeWidth="1dp">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/section_actions"
          android:textAppearance="?attr/textAppearanceTitleMedium"
          android:textColor="@color/text_primary"
          android:textSize="22sp"
          android:textStyle="bold" />

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="14dp"
          android:orientation="horizontal">

          <Button
            android:id="@+id/pasteButton"
            style="@style/WidgetActionButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/action_paste" />

          <Space
            android:layout_width="12dp"
            android:layout_height="1dp" />

          <Button
            android:id="@+id/saveButton"
            style="@style/WidgetActionButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/action_save" />
        </LinearLayout>

        <Button
          android:id="@+id/pasteRefreshButton"
          style="@style/WidgetPrimaryButton"
          android:layout_width="match_parent"
          android:layout_height="56dp"
          android:layout_marginTop="12dp"
          android:text="@string/action_paste_refresh" />

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="12dp"
          android:orientation="horizontal">

          <Button
            android:id="@+id/refreshButton"
            style="@style/WidgetActionButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/action_refresh" />

          <Space
            android:layout_width="12dp"
            android:layout_height="1dp" />

          <Button
            android:id="@+id/pinWidgetButton"
            style="@style/WidgetActionButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/action_pin_widget" />
        </LinearLayout>
      </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:layout_marginBottom="24dp"
      app:cardBackgroundColor="@color/card_surface"
      app:cardCornerRadius="24dp"
      app:strokeColor="@color/card_stroke"
      app:strokeWidth="1dp">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/section_status"
          android:textAppearance="?attr/textAppearanceTitleMedium"
          android:textColor="@color/text_primary"
          android:textSize="22sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/statusText"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="12dp"
          android:background="@drawable/input_bg"
          android:padding="14dp"
          android:textAppearance="?attr/textAppearanceBodyMedium"
          android:textColor="@color/text_secondary"
          android:textSize="15sp"
          android:lineSpacingExtra="3dp" />
      </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
  </LinearLayout>
</ScrollView>
