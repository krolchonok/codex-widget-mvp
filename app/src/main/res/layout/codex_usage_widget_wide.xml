<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widgetRoot"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/widget_bg"
  android:clickable="true"
  android:focusable="true"
  android:orientation="vertical"
  android:paddingStart="16dp"
  android:paddingTop="14dp"
  android:paddingEnd="16dp"
  android:paddingBottom="14dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:gravity="center_vertical"
    android:orientation="vertical">

    <ProgressBar
      android:id="@+id/widgetPrimaryProgress"
      style="?android:attr/progressBarStyleHorizontal"
      android:layout_width="match_parent"
      android:layout_height="12dp"
      android:indeterminate="false"
      android:max="100"
      android:progress="0"
      android:padding="0dp"
      android:progressDrawable="@drawable/widget_progress_primary" />

    <TextView
      android:id="@+id/widgetPrimaryCaption"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:gravity="center"
      android:text="Primary limit"
      android:textColor="@color/widget_text_primary"
      android:textSize="13sp"
      android:maxLines="1"
      android:ellipsize="end" />
  </LinearLayout>

  <TextView
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:background="@color/widget_divider"
    android:text="" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:gravity="center_vertical"
    android:orientation="vertical">

    <ProgressBar
      android:id="@+id/widgetSecondaryProgress"
      style="?android:attr/progressBarStyleHorizontal"
      android:layout_width="match_parent"
      android:layout_height="12dp"
      android:indeterminate="false"
      android:max="100"
      android:progress="0"
      android:padding="0dp"
      android:progressDrawable="@drawable/widget_progress_secondary" />

    <TextView
      android:id="@+id/widgetSecondaryCaption"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:gravity="center"
      android:text="Secondary limit"
      android:textColor="@color/widget_text_primary"
      android:textSize="13sp"
      android:maxLines="1"
      android:ellipsize="end" />
  </LinearLayout>

  <TextView
    android:id="@+id/widgetUpdated"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:gravity="center"
    android:textColor="@color/widget_text_secondary"
    android:textSize="12sp"
    android:maxLines="1"
    android:ellipsize="end" />
</LinearLayout>
